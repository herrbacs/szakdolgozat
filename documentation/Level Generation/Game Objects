#Game Objects
Wall:
    Id: Guid
    Color: string
    Exit: null |Exit
    Pickables: array<Pickable>
    Inspectables: array<Inspectable>
    Interactables: array<Interactable>

Exit:
    Type: LOCK | PASSWORD
    KeyId: null | Guid
    Password: null | string
    Sprite: SpriteAnimation

Pickable:
    Id: Guid
    Position: PositionEnum
    Sprite: Sprite
    Reusable: bool

Inspectable:
    Id: Guid
    Position: PositionEnum
    Data:
        Appellation: string
        Information: string
    Sprite: Sprite

